@{
    ViewBag.Title = "InterfazHubSpot";
}

<h3>Flujo 2A &mdash; Sincronización Clientes / Contactos</h3>
<p>El ERP encola clientes vía <code>USER_POS_Clientes_Agregar</code>. El job lee la cola, ejecuta <code>InterfazHubSpot_Cliente_Obtener</code> (empresa + direcciones), upsert en HubSpot, luego <code>InterfazHubSpot_Clientes_Contactos_Obtener</code> y sincroniza contactos.</p>

<fieldset style="margin-bottom:12px;padding:10px;">
    <legend><strong>Paso 1 &mdash; Cola MSGestion</strong></legend>
    <button type="button" onclick="TrazaCola()">Ver estado de cola (solo lectura, sin reclamar)</button>
    <small>&nbsp;— conteos Pendiente / EnProceso + muestra hasta 40 filas</small>
</fieldset>

<fieldset style="margin-bottom:12px;padding:10px;">
    <legend><strong>Paso 2 &mdash; SP 004 empresa + direcciones (sin HubSpot ni contactos)</strong></legend>
    <label>ClienteId (Mastersoft):</label>
    <input type="number" id="txtClienteId" style="width:130px;" min="1" step="1" placeholder="ej. 12345" />
    <button type="button" onclick="TrazaSpCliente()">SP datos cliente</button>
    <small>&nbsp;— <code>InterfazHubSpot_Cliente_Obtener</code>: cabecera + TOP 3 direcciones de entrega</small>
</fieldset>

<fieldset style="margin-bottom:12px;padding:10px;">
    <legend><strong>Paso 3 &mdash; Buscar empresa en HubSpot (por mastersoft_id_)</strong></legend>
    ClienteId arriba <span style="color:#777;">&#8593;</span> (mismo campo)
    <button type="button" onclick="TrazaHubSpotBuscarEmpresa()">Buscar empresa en HubSpot</button>
    <small>&nbsp;— POST /crm/v3/objects/companies/search por mastersoft_id_</small>
</fieldset>

<fieldset style="margin-bottom:12px;padding:10px;">
    <legend><strong>Paso 4 &mdash; Crear o actualizar empresa en HubSpot</strong></legend>
    ClienteId arriba <span style="color:#777;">&#8593;</span> (mismo campo)
    <button type="button" onclick="TrazaHubSpotUpsertEmpresa()">SP + crear/actualizar empresa HubSpot</button>
    <small>&nbsp;— SP 004 &rarr; search en HS &rarr; POST (nueva) o PATCH (existente)</small>
</fieldset>

<fieldset style="margin-bottom:12px;padding:10px;">
    <legend><strong>Paso 5 &mdash; Buscar contacto en HubSpot (por email)</strong></legend>
    <label>Email del contacto:</label>
    <input type="text" id="txtEmail" style="width:260px;" placeholder="ej. contacto@empresa.com" />
    <button type="button" onclick="TrazaHubSpotBuscarContacto()">Buscar contacto en HubSpot</button>
    <small>&nbsp;— POST /crm/v3/objects/contacts/search por email</small>
</fieldset>

<fieldset style="margin-bottom:12px;padding:10px;">
    <legend><strong>Paso 6 &mdash; Sincronizar todos los contactos del cliente</strong></legend>
    ClienteId arriba <span style="color:#777;">&#8593;</span> (mismo campo) &nbsp;
    <label>HubSpot Company ID:</label>
    <input type="text" id="txtHubCompanyId" style="width:160px;" placeholder="ej. 12345678" />
    <button type="button" onclick="TrazaHubSpotSincronizarContactos()">SP + sincronizar contactos</button>
    <br /><small>SP 005 <code>InterfazHubSpot_Clientes_Contactos_Obtener</code> &rarr; por contacto: search HS por email &rarr; POST o PATCH &rarr; si fue creado: asociación empresa</small>
    <br /><small><em>Nota: los contactos se sincronizan siempre (tanto si la empresa fue creada como actualizada). Contactos sin email se omiten.</em></small>
</fieldset>

<fieldset style="margin-bottom:12px;padding:10px;background:#f8f8f8;">
    <legend><strong>Corrida completa 2A</strong></legend>
    <button type="button" onclick="TrazaCompleta2A()">Traza: corrida completa 2A (SP + HubSpot, todos los pasos)</button>
    <small>&nbsp;— reclama Pendientes, procesa empresa + contactos, muestra todos los pasos en JSON</small>
    <br /><br />
    <button type="button" onclick="ProcesarColaHubSpot()">Procesar Cola HubSpot (silencioso, igual al servicio de Windows)</button>
    <small>&nbsp;— ejecuta el job completo sin retornar pasos de detalle</small>
</fieldset>

<br />
<h3>Flujo 2B &mdash; Cuenta Corriente Diaria</h3>
<p>Actualiza <code>manejo_cuenta_corriente</code> en todas las compañías HubSpot con el saldo de deuda vigente. Batch de 100 compañías via SP MSGestion. Programado diariamente a las 3:00 AM.</p>

<button type="button" onclick="HubSpotCuentaCorrienteBatch()">Ejecutar Batch Cuenta Corriente (silencioso)</button>

<br /><br />
<h3>Diagnóstico</h3>
<button type="button" onclick="GrabarEmailError()">Grabar email de prueba (verifica config SMTP)</button>

<br /><br />
<p><small>Una sola corrida a la vez entre pestañas. Las corridas con traza marcan filas <code>EnProceso</code> durante el batch. Desarrollo sin token: <code>HubSpot:UseDevelopmentMock=true</code>. Primer test real contra HubSpot: <code>UseDevelopmentMock=false</code> + <code>HubSpot:PrivateAppToken</code> en Web.config y SQL desplegado (<code>scriptsSQL/000_Deploy_All.sql</code>).</small></p>
<label for="txtTrazaBatch">Resultado traza (JSON)</label><br />
<textarea id="txtTrazaBatch" readonly rows="22" cols="120" style="width:98%;font-family:Consolas,Menlo,monospace;font-size:11px;"></textarea>

<script>
    function GrabarEmailError() {
        MSExecuteURLOnServer("/Home/GrabarEmailError");
    }
    function ProcesarColaHubSpot() {
        MSExecuteURLOnServer("/Home/ProcesarColaHubSpot");
    }
    function HubSpotCuentaCorrienteBatch() {
        MSExecuteURLOnServer("/Home/HubSpotCuentaCorrienteBatch");
    }

    function MostrarTrazaEnTextarea(url) {
        var ta = document.getElementById("txtTrazaBatch");
        ta.value = "Ejecutando (AJAX asíncrono, esperar)...";
        MSExecuteURLOnServerAsync(url, function (data) {
            try {
                ta.value = JSON.stringify(data, null, 2);
            } catch (e) {
                ta.value = "Error serializando respuesta: " + e.message;
            }
        }, "", 600000);
    }

    function getClienteId() {
        return document.getElementById("txtClienteId").value.trim();
    }

    // Paso 1
    function TrazaCola() {
        MostrarTrazaEnTextarea("/Home/ProcesarColaHubSpotTrazaCola");
    }

    // Pasos 1-2
    function TrazaSpCliente() {
        var cid = getClienteId();
        var q = cid !== "" ? ("?clienteId=" + encodeURIComponent(cid)) : "";
        MostrarTrazaEnTextarea("/Home/ProcesarColaHubSpotTrazaCliente" + q);
    }

    // Paso 3
    function TrazaHubSpotBuscarEmpresa() {
        var cid = getClienteId();
        if (!cid) { alert("Ingresar ClienteId."); return; }
        MostrarTrazaEnTextarea("/Home/TrazaHubSpotBuscarEmpresa?clienteId=" + encodeURIComponent(cid));
    }

    // Paso 4
    function TrazaHubSpotUpsertEmpresa() {
        var cid = getClienteId();
        if (!cid) { alert("Ingresar ClienteId."); return; }
        MostrarTrazaEnTextarea("/Home/TrazaHubSpotUpsertEmpresa?clienteId=" + encodeURIComponent(cid));
    }

    // Paso 5
    function TrazaHubSpotBuscarContacto() {
        var email = document.getElementById("txtEmail").value.trim();
        if (!email) { alert("Ingresar Email del contacto."); return; }
        MostrarTrazaEnTextarea("/Home/TrazaHubSpotBuscarContacto?email=" + encodeURIComponent(email));
    }

    // Paso 6
    function TrazaHubSpotSincronizarContactos() {
        var cid = getClienteId();
        var hcid = document.getElementById("txtHubCompanyId").value.trim();
        if (!cid) { alert("Ingresar ClienteId."); return; }
        if (!hcid) { alert("Ingresar HubSpot Company ID (obtenido del paso 4)."); return; }
        MostrarTrazaEnTextarea(
            "/Home/TrazaHubSpotSincronizarContactos?clienteId=" + encodeURIComponent(cid) +
            "&hubCompanyId=" + encodeURIComponent(hcid));
    }

    // Corrida completa
    function TrazaCompleta2A() {
        MostrarTrazaEnTextarea("/Home/ProcesarColaHubSpotTraza");
    }
</script>
