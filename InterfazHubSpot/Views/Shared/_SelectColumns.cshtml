                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12">
                        <div id="gridBusSelectColumns" data-bind="source: Resultados" style="height:340px;margin-top:3px;"></div>
                    </div>
                </div>

            </div>
            <div class="modal-footer">
                <button id="butSelectColumnsAceptar" type="button" class="k-button btn btn-default" data-faicon="fa-check">Aceptar</button>
            </div>
        </div>

    </div>
</div>