        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title">Selección de Columnas</h4>
            </div>
            <div class="modal-body">

                <div class="form-group row">
                    <div class="col-md-6">
                    </div>
                    <div class="col-md-6">
                        <button id="butMarcarTodoSelectColumns" class="k-button" type="button" data-role="button" style="margin-right:10px;">Marcar Todo</button>
