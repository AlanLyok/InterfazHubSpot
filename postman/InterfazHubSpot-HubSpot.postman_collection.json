      ]
    },
    {
      "name": "Consola MVC (local)",
      "description": "Endpoints ASP.NET MVC (`localUrl` en el environment). Pasos numerados alineados con `Views/Home/Index.cshtml`.\n\n**Prerrequisito:** desplegar `scriptsSQL/000_Deploy_All.sql` en MSGestion (SP 004, 005, cola). `Web.config` con `MSGestion` + `HubSpot:PrivateAppToken` (o `HubSpot:UseDevelopmentMock=true`).\n\n**Orden smoke sugerido:** Paso 1 → 2 (SP004) → 4 (upsert, guarda hubspotCompanyId) → 6 (SP005+contactos) → corrida completa 2A.\n\nEn corrida completa 2A, el JSON de traza debe mostrar `bd.sp.contactos_obtener` **después** de `destinoexterno.hubspot.company_upsert`.",
      "item": [
        {
          "name": "Paso 1 — Traza cola",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{localUrl}}/Home/ProcesarColaHubSpotTrazaCola",
              "host": ["{{localUrl}}"],
              "path": ["Home", "ProcesarColaHubSpotTrazaCola"]
            },
            "description": "Solo lectura: conteos Pendiente/EnProceso y hasta 40 filas de `dbo.ProcesosSpertaHubSpot`. No reclama filas."
          }
        },
        {
          "name": "Paso 2 — Traza SP 004 (empresa + direcciones)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{localUrl}}/Home/ProcesarColaHubSpotTrazaCliente?clienteId={{mastersoftId}}",
              "host": ["{{localUrl}}"],
              "path": ["Home", "ProcesarColaHubSpotTrazaCliente"],
              "query": [{ "key": "clienteId", "value": "{{mastersoftId}}" }]
            },
            "description": "Ejecuta `dbo.InterfazHubSpot_Cliente_Obtener` (SP 004): cabecera empresa, TOP 3 direcciones de entrega y `ManejoCuentaCorriente`. **Sin HubSpot ni contactos** (SP 005 no se invoca)."
          }
        },
        {
          "name": "Paso 3 — TrazaHubSpotBuscarEmpresa",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{localUrl}}/Home/TrazaHubSpotBuscarEmpresa?clienteId={{mastersoftId}}",
              "host": ["{{localUrl}}"],
              "path": ["Home", "TrazaHubSpotBuscarEmpresa"],
              "query": [{ "key": "clienteId", "value": "{{mastersoftId}}" }]
            },
            "description": "Busca compañía en HubSpot por `cuitcuil_unica` (POST /crm/v3/objects/companies/search). Usa `cuitCuilUnica` del environment; `clienteId` en trazas MVC resuelve el CUIT vía SP 004."
          }
        },
        {
          "name": "Paso 4 — TrazaHubSpotUpsertEmpresa",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "if (pm.response.code === 200) {",
                  "    const j = pm.response.json();",
                  "    if (j.ok && Array.isArray(j.pasos)) {",
                  "        const paso = j.pasos.find(p => p.Codigo === 'destinoexterno.hubspot.company_upsert');",
                  "        const datos = paso && paso.Datos;",
                  "        const id = datos && (datos.hubCompanyId || datos.HubCompanyId);",
                  "        if (id) {",
                  "            pm.environment.set('hubspotCompanyId', String(id));",
                  "            console.log('hubspotCompanyId =', id);",
                  "        } else {",
                  "            console.log('No se encontró hubCompanyId en paso company_upsert; copiar manualmente del JSON de traza.');",
                  "        }",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{localUrl}}/Home/TrazaHubSpotUpsertEmpresa?clienteId={{mastersoftId}}",
              "host": ["{{localUrl}}"],
              "path": ["Home", "TrazaHubSpotUpsertEmpresa"],
              "query": [{ "key": "clienteId", "value": "{{mastersoftId}}" }]
            },
            "description": "SP 004 → search HubSpot → POST (nueva) o PATCH (existente). El test script intenta guardar `hubCompanyId` en la variable `hubspotCompanyId` del environment desde el paso `destinoexterno.hubspot.company_upsert`."
          }
        },
        {
          "name": "Paso 5 — TrazaHubSpotBuscarContacto",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{localUrl}}/Home/TrazaHubSpotBuscarContacto?email={{contactEmail}}",
              "host": ["{{localUrl}}"],
              "path": ["Home", "TrazaHubSpotBuscarContacto"],
              "query": [{ "key": "email", "value": "{{contactEmail}}" }]
            },
            "description": "Busca contacto en HubSpot por email (POST /crm/v3/objects/contacts/search). Variable `contactEmail`."
          }
        },
        {
          "name": "Paso 6 — TrazaHubSpotSincronizarContactos",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{localUrl}}/Home/TrazaHubSpotSincronizarContactos?clienteId={{mastersoftId}}&hubCompanyId={{hubspotCompanyId}}",
              "host": ["{{localUrl}}"],
              "path": ["Home", "TrazaHubSpotSincronizarContactos"],
              "query": [
                { "key": "clienteId", "value": "{{mastersoftId}}" },
                { "key": "hubCompanyId", "value": "{{hubspotCompanyId}}" }
              ]
            },
            "description": "SP 005 `InterfazHubSpot_Clientes_Contactos_Obtener` → upsert contactos → asociación si fueron creados. Requiere `hubspotCompanyId` (Paso 4 o búsqueda HubSpot directa)."
          }
        },
        {
          "name": "Corrida completa 2A — Traza (todos los pasos)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{localUrl}}/Home/ProcesarColaHubSpotTraza",
              "host": ["{{localUrl}}"],
              "path": ["Home", "ProcesarColaHubSpotTraza"]
            },
            "description": "Reclama filas Pendientes y ejecuta flujo 2A completo con JSON paso a paso. Verificar orden: `company_upsert` antes de `bd.sp.contactos_obtener`."
