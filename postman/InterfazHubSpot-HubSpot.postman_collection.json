{
  "info": {
    "name": "InterfazHubSpot — HubSpot CRM v3",
    "description": "Pruebas HubSpot CRM v3 (Private App Token) + consola MVC local.\n\n**Setup:** importar `InterfazHubSpot-Dev.postman_environment.json`, activar el environment y completar `privateAppToken` (pat-na1-...).\n\nVer `postman/README.md` para orden de prueba.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{privateAppToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "0 — Auth y conexión",
      "description": "Verificar PAT antes de probar 2A/2B. Un 401 indica token inválido; un 403 indica scopes insuficientes.",
      "item": [
        {
          "name": "POST Verificar PAT (scopes)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "if (pm.response.code === 200) {",
                  "    const j = pm.response.json();",
                  "    console.log('hubId:', j.hubId, 'scopes:', j.scopes);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tokenKey\": \"{{privateAppToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/oauth/v2/private-apps/get/access-token-info",
              "host": ["{{baseUrl}}"],
              "path": ["oauth", "v2", "private-apps", "get", "access-token-info"]
            },
            "description": "Inspecciona hubId, appId y scopes del PAT. No requiere header Authorization."
          }
        },
        {
          "name": "GET Propiedades de compañía (smoke token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Token válido (200)', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/crm/v3/properties/companies?limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["crm", "v3", "properties", "companies"],
              "query": [{ "key": "limit", "value": "5" }]
            },
            "description": "Llamada mínima autenticada. 200 = Bearer OK. 401 = token inválido/revocado."
          }
        },
        {
          "name": "GET Listar compañías (limit 1)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/crm/v3/objects/companies?limit=1&properties=name,{{propertyMastersoftId}}",
              "host": ["{{baseUrl}}"],
              "path": ["crm", "v3", "objects", "companies"],
              "query": [
                { "key": "limit", "value": "1" },
                { "key": "properties", "value": "name,{{propertyMastersoftId}}" }
              ]
            },
            "description": "Smoke adicional de lectura CRM objects."
          }
        }
      ]
    },
    {
      "name": "Flujo 2A — Compañías",
      "item": [
        {
          "name": "POST Buscar compañía por mastersoft_id_",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const j = pm.response.json();",
                  "    if (j.results && j.results.length > 0 && j.results[0].id) {",
                  "        pm.environment.set('hubspotCompanyId', j.results[0].id);",
                  "        console.log('hubspotCompanyId =', j.results[0].id);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"filterGroups\": [\n    {\n      \"filters\": [\n        {\n          \"propertyName\": \"{{propertyMastersoftId}}\",\n          \"operator\": \"EQ\",\n          \"value\": \"{{mastersoftId}}\"\n        }\n      ]\n    }\n  ],\n  \"properties\": [\"name\", \"{{propertyMastersoftId}}\", \"{{propertyManejoCc}}\"],\n  \"limit\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/crm/v3/objects/companies/search",
              "host": ["{{baseUrl}}"],
              "path": ["crm", "v3", "objects", "companies", "search"]
            },
            "description": "Igual que HubSpotCrmClient.SearchCompanyIdByMastersoftIdAsync. Si total > 0 → PATCH; si no → POST."
          }
        },
        {
          "name": "POST Crear compañía",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "    const j = pm.response.json();",
                  "    if (j.id) {",
                  "        pm.environment.set('hubspotCompanyId', j.id);",
                  "        console.log('hubspotCompanyId =', j.id);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"properties\": {\n    \"name\": \"EMPRESA DE PRUEBA SA\",\n    \"{{propertyMastersoftId}}\": \"{{mastersoftId}}\",\n    \"nro_cliente\": \"99999\",\n    \"cuitcuil\": \"30-99999999-0\",\n    \"nombre_fantasia\": \"Empresa Prueba\",\n    \"adress\": \"Av. Corrientes 1234\",\n    \"city\": \"Buenos Aires\",\n    \"zip\": \"C1043\",\n    \"state\": \"Buenos Aires\",\n    \"Country\": \"Argentina\",\n    \"zona_vta\": \"CABA\",\n    \"vendedor\": \"VENDEDOR TEST\",\n    \"responsable_de_cuenta\": \"ALAN L\",\n    \"lista_de_precios\": \"Lista A\",\n    \"condicion_de_venta\": \"30 dias\",\n    \"dias_para_deuda\": \"30\",\n    \"limite_de_credito\": \"100000\",\n    \"categoria_cliente\": \"A\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/crm/v3/objects/companies",
              "host": ["{{baseUrl}}"],
              "path": ["crm", "v3", "objects", "companies"]
            },
            "description": "Crea compañía. El test script guarda el id en hubspotCompanyId."
          }
        },
        {
          "name": "PATCH Actualizar compañía",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"properties\": {\n    \"name\": \"EMPRESA DE PRUEBA SA (actualizada)\",\n    \"zona_vta\": \"GBA\",\n    \"condicion_de_venta\": \"60 dias\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/crm/v3/objects/companies/{{hubspotCompanyId}}",
              "host": ["{{baseUrl}}"],
              "path": ["crm", "v3", "objects", "companies", "{{hubspotCompanyId}}"]
            },
            "description": "Requiere hubspotCompanyId (search o create previo)."
          }
        },
        {
          "name": "GET Compañía por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/crm/v3/objects/companies/{{hubspotCompanyId}}?properties=name,{{propertyMastersoftId}},{{propertyManejoCc}}",
              "host": ["{{baseUrl}}"],
              "path": ["crm", "v3", "objects", "companies", "{{hubspotCompanyId}}"],
              "query": [
                { "key": "properties", "value": "name,{{propertyMastersoftId}},{{propertyManejoCc}}" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Flujo 2A — Contactos",
      "item": [
        {
          "name": "POST Buscar contacto por email",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const j = pm.response.json();",
                  "    if (j.results && j.results.length > 0 && j.results[0].id) {",
                  "        pm.environment.set('hubspotContactId', j.results[0].id);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"filterGroups\": [\n    {\n      \"filters\": [\n        {\n          \"propertyName\": \"email\",\n          \"operator\": \"EQ\",\n          \"value\": \"{{contactEmail}}\"\n        }\n      ]\n    }\n  ],\n  \"properties\": [\"firstname\", \"email\", \"phone\", \"sector\"],\n  \"limit\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/crm/v3/objects/contacts/search",
              "host": ["{{baseUrl}}"],
              "path": ["crm", "v3", "objects", "contacts", "search"]
            }
          }
        },
        {
          "name": "POST Crear contacto",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "    const j = pm.response.json();",
                  "    if (j.id) pm.environment.set('hubspotContactId', j.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"properties\": {\n    \"firstname\": \"Juan\",\n    \"email\": \"{{contactEmail}}\",\n    \"phone\": \"011-4444-5555\",\n    \"sector\": \"Compras\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/crm/v3/objects/contacts",
              "host": ["{{baseUrl}}"],
              "path": ["crm", "v3", "objects", "contacts"]
            }
          }
        },
        {
          "name": "PATCH Actualizar contacto",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"properties\": {\n    \"phone\": \"011-9999-8888\",\n    \"sector\": \"Administración\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/crm/v3/objects/contacts/{{hubspotContactId}}",
              "host": ["{{baseUrl}}"],
              "path": ["crm", "v3", "objects", "contacts", "{{hubspotContactId}}"]
            }
          }
        },
        {
          "name": "PUT Asociar contacto a compañía",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": {
              "raw": "{{baseUrl}}/crm/v3/objects/contacts/{{hubspotContactId}}/associations/companies/{{hubspotCompanyId}}/contact_to_company",
              "host": ["{{baseUrl}}"],
              "path": [
                "crm", "v3", "objects", "contacts", "{{hubspotContactId}}",
                "associations", "companies", "{{hubspotCompanyId}}", "contact_to_company"
              ]
            },
            "description": "HubSpotCrmClient.AssociateContactToCompanyAsync — solo tras POST contacto nuevo."
          }
        }
      ]
    },
    {
      "name": "Flujo 2B — Cuenta Corriente Batch",
      "item": [
        {
          "name": "POST Batch update — con deuda",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"inputs\": [\n    {\n      \"id\": \"{{hubspotCompanyId}}\",\n      \"properties\": {\n        \"{{propertyManejoCc}}\": \"15/03/2026 --- $125.400,00\\n02/04/2026 --- $89.200,50\"\n      }\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/crm/v3/objects/companies/batch/update",
              "host": ["{{baseUrl}}"],
              "path": ["crm", "v3", "objects", "companies", "batch", "update"]
            },
            "description": "Hasta 100 registros por request. Formato línea: DD/MM/YYYY --- $monto"
          }
        },
        {
          "name": "POST Batch update — sin deuda (limpiar)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"inputs\": [\n    {\n      \"id\": \"{{hubspotCompanyId}}\",\n      \"properties\": {\n        \"{{propertyManejoCc}}\": \"\"\n      }\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/crm/v3/objects/companies/batch/update",
              "host": ["{{baseUrl}}"],
              "path": ["crm", "v3", "objects", "companies", "batch", "update"]
            }
          }
        }
      ]
    },
    {
      "name": "Flujo 1 — Referencia (webhook, no implementado)",
      "description": "Endpoints del PDF v3 HubSpot→ERP. InterfazHubSpot NO los implementa. Salientes usan el mismo PAT; entrantes usan clientSecret para validar firma.",
      "item": [
        {
          "name": "GET Compañía + propiedades (webhook follow-up)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/crm/v3/objects/companies/{{hubspotCompanyId}}?properties=name,domain,phone,address,city,state,country,zip,industry&associations=contacts",
              "host": ["{{baseUrl}}"],
              "path": ["crm", "v3", "objects", "companies", "{{hubspotCompanyId}}"],
              "query": [
                { "key": "properties", "value": "name,domain,phone,address,city,state,country,zip,industry" },
                { "key": "associations", "value": "contacts" }
              ]
            }
          }
        },
        {
          "name": "GET Asociaciones contactos de compañía",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/crm/v3/objects/companies/{{hubspotCompanyId}}/associations/contacts",
              "host": ["{{baseUrl}}"],
              "path": ["crm", "v3", "objects", "companies", "{{hubspotCompanyId}}", "associations", "contacts"]
            }
          }
        },
        {
          "name": "POST Batch read contactos",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"inputs\": [{ \"id\": \"{{hubspotContactId}}\" }],\n  \"properties\": [\"firstname\", \"lastname\", \"email\", \"phone\", \"jobtitle\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/crm/v3/objects/contacts/batch/read",
              "host": ["{{baseUrl}}"],
              "path": ["crm", "v3", "objects", "contacts", "batch", "read"]
            }
          }
        },
        {
          "name": "POST Crear nota de error en compañía",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"properties\": {\n    \"hs_note_body\": \"ERROR de prueba Postman — compañía {{hubspotCompanyId}}\",\n    \"hs_timestamp\": \"{{$timestamp}}000\"\n  },\n  \"associations\": [\n    {\n      \"to\": { \"id\": \"{{hubspotCompanyId}}\" },\n      \"types\": [\n        {\n          \"associationCategory\": \"HUBSPOT_DEFINED\",\n          \"associationTypeId\": 190\n        }\n      ]\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/crm/v3/objects/notes",
              "host": ["{{baseUrl}}"],
              "path": ["crm", "v3", "objects", "notes"]
            },
            "description": "Solo referencia PDF §3.2. No ejecutar en producción sin cuidado."
          }
        }
      ]
    },
    {
      "name": "Consola MVC (local)",
      "description": "Endpoints ASP.NET MVC. Variable localUrl en el environment.",
      "item": [
        {
          "name": "POST Procesar Cola HubSpot (2A silencioso)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{localUrl}}/Home/ProcesarColaHubSpot",
              "host": ["{{localUrl}}"],
              "path": ["Home", "ProcesarColaHubSpot"]
            }
          }
        },
        {
          "name": "POST Traza: ver estado de cola",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{localUrl}}/Home/ProcesarColaHubSpotTrazaCola",
              "host": ["{{localUrl}}"],
              "path": ["Home", "ProcesarColaHubSpotTrazaCola"]
            }
          }
        },
        {
          "name": "POST Traza: SP datos de cliente (sin HubSpot)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{localUrl}}/Home/ProcesarColaHubSpotTrazaCliente?clienteId={{mastersoftId}}",
              "host": ["{{localUrl}}"],
              "path": ["Home", "ProcesarColaHubSpotTrazaCliente"],
              "query": [{ "key": "clienteId", "value": "{{mastersoftId}}" }]
            }
          }
        },
        {
          "name": "POST Traza: corrida completa 2A (SP + HubSpot)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{localUrl}}/Home/ProcesarColaHubSpotTraza",
              "host": ["{{localUrl}}"],
              "path": ["Home", "ProcesarColaHubSpotTraza"]
            }
          }
        },
        {
          "name": "POST Batch Cuenta Corriente (2B silencioso)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{localUrl}}/Home/HubSpotCuentaCorrienteBatch",
              "host": ["{{localUrl}}"],
              "path": ["Home", "HubSpotCuentaCorrienteBatch"]
            }
          }
        },
        {
          "name": "POST Grabar email de prueba",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{localUrl}}/Home/GrabarEmailError",
              "host": ["{{localUrl}}"],
              "path": ["Home", "GrabarEmailError"]
            }
          }
        }
      ]
    }
  ]
}
