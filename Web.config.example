<?xml version="1.0" encoding="utf-8"?>
<!--
  Plantilla post-refactor InterfazHubSpot.
  Copiar a InterfazHubSpot/Web.config (no versionado) y completar secretos localmente.
-->
<configuration>
  <connectionStrings>
    <add name="MSFwk" connectionString="Data Source=SERVER;Initial Catalog=MsFramework_XXX;..." />
    <add name="MSGestion" connectionString="Data Source=SERVER;Initial Catalog=MsGestion_XXX;..." />
  </connectionStrings>
  <appSettings>
    <add key="ErrorLogConnectionName" value="InterfazHubSpot" />
    <add key="Title" value="InterfazHubSpot" />
    <add key="FrameworkCNPrefix" value="InterfazHubSpot" />
    <add key="PathLog" value="C:\logs\InterfazHubSpot\InterfazHubSpot.txt" />
    <add key="HubSpot:PrivateAppToken" value="" />
    <add key="HubSpot:UseDevelopmentMock" value="true" />
  </appSettings>
  <system.web>
    <authentication mode="Forms">
      <forms name="InterfazHubSpot" loginUrl="~/Account/Login" timeout="2880" />
    </authentication>
  </system.web>
</configuration>
