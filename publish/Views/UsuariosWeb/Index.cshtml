
@{
    ViewBag.Title = "Mantenimiento de Usuarios";
}

@section Scripts {
    @Scripts.Render("~/bundles/AbmUsuariosWeb")
}


<br />
<h3>Mantenimiento de Usuarios</h3>

<div id="rootwizard">

    <div id="Abm">

        <ul>
            <li style="display:none"><a href="#tab1" data-toggle="tab"></a></li>
            <li style="display:none"><a href="#tab2" data-toggle="tab"></a></li>
        </ul>

        <div class="tab-content">

            <div class="tab-pane" id="tab1">

                <div class="row">
                    <div class="col-md-12">
                        <div id="gridIniUsuariosWeb" data-bind="source: Resultados" style="height:320px;"></div>
                    </div>
                </div>

                <div class="row top5">
                    <div class="col-md-12">
                        <span id="statusMessage" class="ms-redlabel" data-bind="text: recordMessage"></span>
                    </div>
                </div>

                <br />

                <div class="row">
                    <div class="col-md-12">
                        <button id="butAgregar" class="k-button" type="button" data-role="button" data-bind="disabled: isAddNewDisabled" style="margin-right:15px;margin-bottom:10px;">Agregar</button>
                        <button id="butModificar" class="k-button" type="button" data-role="button" data-bind="disabled: isDeleteDisabled" style="margin-right:15px;margin-bottom:10px;">Modificar</button>
                        <button id="butEliminar" class="k-button" type="button" data-role="button" data-bind="disabled: isDeleteDisabled" style="margin-right:15px;margin-bottom:10px;">Eliminar</button>
                    </div>
                </div>

            </div>

            <div class="tab-pane" id="tab2">

                <div class="form-group row">
                    <div class="col-md-4">
                        <label>Usuario *</label>
                        <div class="form-group-field">
                            <input id="Usuario" type="text" class="k-textbox" data-bind="value: UsuariosWeb.Usuario, disabled: isControlDisabled" maxlength="100" autocomplete="off" spellcheck="false" style="max-width:375px" />
                            <img id="errUsuario" src="~/Content/Images/error.png" style="display:none" />
                        </div>
                    </div>
                </div>

                <div class="form-group row">
                    <div class="col-md-4">
                        <label>Nombre Completo *</label>
                        <div class="form-group-field">
                            <input id="NombreCompleto" type="text" class="k-textbox" data-bind="value: UsuariosWeb.NombreCompleto, disabled: isControlDisabled" maxlength="100" autocomplete="off" spellcheck="false" style="max-width:375px" />
                            <img id="errNombreCompleto" src="~/Content/Images/error.png" style="display:none" />
                        </div>
                    </div>
                </div>

                <div class="form-group row">
                    <div class="col-md-2">
                        <label>Contraseña</label>
                        <div class="form-group-field">
                            <input id="Password" type="password" class="k-textbox" data-bind="value: UsuariosWeb.Password, disabled: isControlDisabled" maxlength="15" style="max-width:162px" />
                            <img id="errPassword" src="~/Content/Images/error.png" style="display:none" />
                        </div>
                    </div>
                </div>

                <div class="form-group row">

                    <div class="col-md-3">
                        <label>Doble Factor de Autenticación</label>
                        <div class="form-group-field">
                            <input id="UsaDobleFactor" type="checkbox" data-bind="checked: UsuariosWeb.UsaDobleFactor, disabled: isControlDisabled" />
                        </div>
                    </div>

                    <div id="divMuestraQR" class="col-md-4">
                        <label>Muestra QR</label>
                        <div class="form-group-field">
                            <input id="MuestraQR" type="checkbox" data-bind="checked: UsuariosWeb.MuestraQR, disabled: isControlDisabled" />
                        </div>
                    </div>

                </div>

                <div class="form-group row">
                    <div class="col-md-4">
                        <label>Perfil *</label>
                        <div class="form-group-field">
                            <select id="PerfilId" data-bind="source: PerfilesWebCombo, value: UsuariosWeb.PerfilId, disabled: isControlDisabled" style="max-width:375px"></select>
                            <img id="errPerfilId" src="~/Content/Images/error.png" style="display:none" />
                        </div>
                    </div>
                </div>

                <hr>

                <div class="row">
                    <div class="col-md-12">
                        <button id="butAceptar" class="k-primary" type="button" data-role="button" style="margin-right:15px;">Aceptar</button>
                        <button id="butCancelar" class="k-button" type="button" data-role="button" style="margin-right:15px;">Cancelar</button>
                    </div>
                </div>

            </div>

        </div>

    </div>
</div>


