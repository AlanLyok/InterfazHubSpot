<?xml version="1.0" encoding="utf-8"?>
<!--
  Plantilla para MSScheduler452Service.exe.config (servicio Windows Scheduler452).
  Copiar a MSScheduler452Service.exe.config y completar secretos localmente.
  Debe coincidir con InterfazHubSpot/Web.config en MSGestion + claves HubSpot.

  Instalacion del servicio:
    sc.exe create ServicioInterfazHubSpot binPath= "C:\Ruta\...\MSScheduler452Service.exe" start= auto
-->
<configuration>
  <configSections>
    <section name="entityFramework" type="System.Data.Entity.Internal.ConfigFile.EntityFrameworkSection, EntityFramework, Version=6.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" requirePermission="false" />
  </configSections>
  <connectionStrings>
    <add name="MSGestion"
         connectionString="Data Source=MS0025;Initial Catalog=MsGestion_CALZETTA;Integrated Security=True;MultipleActiveResultSets=True"
         providerName="System.Data.SqlClient" />
  </connectionStrings>
  <appSettings>
    <add key="FrameworkCNPrefix" value="InterfazHubSpot" />
    <add key="EmpresaId" value="1" />
    <add key="PathLog" value="C:\logs\InterfazHubSpot\MSScheduler452Service.txt" />
    <add key="EmailErrDE" value="" />
    <add key="EmailErrPara" value="" />
    <add key="HubSpot:PrivateAppToken" value="" />
    <add key="HubSpot:UseDevelopmentMock" value="false" />
  </appSettings>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.5.2" />
  </startup>
  <entityFramework>
    <providers>
      <provider invariantName="System.Data.SqlClient" type="System.Data.Entity.SqlServer.SqlProviderServices, EntityFramework.SqlServer" />
    </providers>
  </entityFramework>
</configuration>
