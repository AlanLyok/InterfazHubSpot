# Copiar este archivo como `.env` en esta misma carpeta (NO commitear).
# Credenciales = solo servidor de desarrollo; usuario SQL con permisos mínimos recomendados.
#
# Documentación del proyecto: ../../docs/how-to/mcp-mssql-desarrollo-cursor.md

MSSQL_HOST=localhost
MSSQL_USER=spertadev_readonly
MSSQL_PASSWORD=CAMBIAME
MSSQL_DATABASE=MSGestion
# Ejemplo ODBC en Windows (ajustar al driver instalado en tu máquina):
# ODBC Driver 18 for SQL Server / ODBC Driver 17 for SQL Server
MSSQL_DRIVER=ODBC Driver 17 for SQL Server
TrustServerCertificate=yes
Trusted_Connection=no
