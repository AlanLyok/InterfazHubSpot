MSSQL_HOST=MS0025
# Con Trusted_Connection=yes el paquete MCP exige USER/PASSWORD no vacíos; ODBC ignora UID/PWD.
MSSQL_USER=windows
MSSQL_PASSWORD=windows
MSSQL_DATABASE=MsGestion_CALZETTA
# Ejemplo ODBC en Windows (ajustar al driver instalado en tu máquina):
# ODBC Driver 18 for SQL Server / ODBC Driver 17 for SQL Server
MSSQL_DRIVER=ODBC Driver 17 for SQL Server
TrustServerCertificate=yes
Trusted_Connection=yes
